# =============================================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА — скопируй в .env:  cp .env.example .env
# Пароль БД не короче 10 символов (так устроен db.js).
# =============================================================================

NODE_ENV=development

# --- PostgreSQL (отдельная тестовая БД) ---
PGUSER=test_bilet
PGHOST=localhost
PGDATABASE=pokupka_biletov_dev
PGPASSWORD=testpass_local_1
PGPORT=5432

# --- БД «билетов» (ticketDb.js) — локально совпадает с основной БД ---
TICKET_PGUSER=test_bilet
TICKET_PGHOST=localhost
TICKET_PGDATABASE=pokupka_biletov_dev
TICKET_PGPASSWORD=testpass_local_1
TICKET_PGPORT=5432

# --- Сервер API ---
PORT=3000

# Локально фронт на Vite
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Прод: https://biletvsem.com — sitemap, SSR meta, письма
# Для ссылок в письмах и sitemap (локально)
SITE_URL=http://localhost:5173
API_INTERNAL_URL=http://127.0.0.1:3000

# Авторизация: на dev часто отключают проверку JWT на публичных роутах
AUTH_REQUIRED=false

# JWT (минимум ~32 символа для прод; для локалки достаточно длинной строки)
JWT_SECRET=dev-jwt-secret-key-minimum-32-characters-long-ok

# Тестовый админ (подставь свою почту, если залогиниться в админку)
ADMIN_EMAIL=admin@test.local
ADMIN_PASSWORD=TestAdmin_Pass_123

# =============================================================================
# GetBilet
# =============================================================================
# GETBILET_API_BASE=https://api.getbilet.ru
# GETBILET_API_TIMEOUT_MS=25000
#
# auto (по умолчанию): если заданы GETBILET_USER_ID + GETBILET_HASH → rest_v2, иначе BIL24
# GETBILET_PROTOCOL=auto
#
# --- Режим A: BIL24 JSON (command + fid + token на /json) — как bil24.pro ---
# GETBILET_PROTOCOL=bil24_json
# GETBILET_API_KEY=токен_интерфейса
# GETBILET_INTERFACE_FID=число
#
# --- Режим B: произвольный REST (Bearer/Basic) ---
# GETBILET_PROTOCOL=rest
# GETBILET_AUTH_MODE=bearer
# GETBILET_API_KEY=
# GETBILET_API_SECRET=
# GETBILET_REST_EVENTS_PATH=/events
#
# --- Режим C: официальный REST API GetBilet v2.2 (док. 31-10-2025) ---
# POST Auth/GetToken (UserId+Hash) → x-access-token. Каталог GET /api/bilet/events без GETBILET_V2_STAGE_IDS:
# обход GetPlaceList → GetStageListByPlaceId → репертуар (все доступные площадки/сцены, дедуп по репертуару).
# GETBILET_PROTOCOL=rest_v2
# GETBILET_USER_ID=
# GETBILET_HASH=
# Опционально: только эти сцены (иначе авто)
# GETBILET_V2_STAGE_IDS=
# Опционально: ограничить площадки и объём (защита от таймаута)
# GETBILET_V2_CATALOG_PLACE_IDS=
# GETBILET_V2_CATALOG_MAX_PLACES=50
# GETBILET_V2_CATALOG_MAX_STAGES=300
# Одна карточка на афише = один сеанс (запрос GetOfferListByRepertoireId на каждый спектакль). 0|false — одна карточка на репертуар.
# GETBILET_V2_CATALOG_EXPAND_SESSIONS=1
# Параллельные запросы офферов при развёртке (не раздуливать — лимиты GetBilet)
# GETBILET_V2_CATALOG_EXPAND_CONCURRENCY=6
# GETBILET_REST_V2_PATH_PREFIX=
# GETBILET_V2_WRITE_SECRET=
#
# Афиши без картинок в API: шаблоны CDN/статики — подстановка {repertoireId} или {id}
# GETBILET_POSTER_URL_TEMPLATE=https://cdn.example.com/posters/{repertoireId}.jpg
# GETBILET_BANNER_URL_TEMPLATE=https://cdn.example.com/banners/{repertoireId}.jpg
#
# Постер со страницы театра (админ: «Подтянуть постер» / batch-fetch): ограничение хостов; пусто = любые
# POSTER_PAGE_ALLOWLIST_HOSTS=mxat.ru,www.mxat.ru,neglinka29.ru
#
# Автоматизация обложек:
# 1) POST /api/admin/getbilet/sync-catalog — в getbilet_events подставляет poster_page_url из полей URL в сыром каталоге GetBilet (SiteUrl, Place.Url, …), если колонка ещё пуста.
# 2) POST /api/admin/getbilet/events/batch-fetch-posters  body: {"limit":50,"delay_ms":600} — по заполненным poster_page_url тянет og:image в poster_url_manual (админ JWT).
# POSTER_PAGE_FETCH_TIMEOUT_MS=18000
# POSTER_PAGE_MAX_HTML_BYTES=2800000
#
# Обложки по названию (режим auto): сначала Google Image Search (CSE), при пустом ответе/ошибке — OpenAI (если задан ключ).
# POSTER_SEARCH_PROVIDER=auto
# auto | google | openai — только один источник для google/openai.
# После Google не вызывать OpenAI: POSTER_AUTO_OPENAI_FALLBACK=0
# OpenAI (те же переменные для AI-чата): POSTER_OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# OPENAI_PROXY_URL=
# При 403 «Country, region, or territory not supported» (геоблок с вашего IP):
# — задайте OPENAI_PROXY_URL с выходом в US/EU, или полный URL:
# OPENAI_API_BASE_URL=https://your-worker.example/v1/chat/completions
# — либо OpenAI-совместимый шлюз (например OpenRouter):
# OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...   # ключ OpenRouter
# EVENT_DESCRIPTION_OPENAI_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://your-site.example
# Не отключать повторные запросы к LLM после ошибки (только отладка): OPENAI_DISABLE_UPSTREAM_CIRCUIT=1
#
# Тексты страниц мероприятий (репертуар): при наличии OPENAI_API_KEY по умолчанию включается ИИ-проза.
# Отключить: EVENT_DESCRIPTION_USE_OPENAI=0
# Модель (по умолчанию gpt-4o-mini): EVENT_DESCRIPTION_OPENAI_MODEL=gpt-4o-mini
# Всегда перегенерировать ИИ даже при длинном ручном тексте: EVENT_DESCRIPTION_AI_ALWAYS=1
#
# Google Programmable Search (Image search в настройках движка):
# https://programmablesearchengine.google.com/
# https://developers.google.com/custom-search/v1/overview
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# В запрос подставляется точная фраза названия в кавычках + суффикс (phrase match). Отключить кавычки: POSTER_WEB_SEARCH_EXACT_PHRASE=0
# POSTER_WEB_SEARCH_EXACT_PHRASE=1
# Суффикс к запросу (пустая строка = только название в кавычках). По умолчанию: «афиша спектакль»
# POSTER_WEB_SEARCH_QUERY_SUFFIX=афиша спектакль
# POSTER_WEB_SEARCH_LR=lang_ru
# POSTER_WEB_SEARCH_NUM_RESULTS=5
# POSTER_WEB_SEARCH_TIMEOUT_MS=12000
# Сначала — индекс Google по доменам (должны быть в списке сайтов Programmable Search Engine). Несколько через запятую.
# Пример: Яндекс Афиша + PortalBilet — https://afisha.yandex.ru/moscow
# POSTER_WEB_SEARCH_IMAGE_SITE=afisha.yandex.ru,portalbilet.ru
# POSTER_WEB_SEARCH_IMAGE_SITE_FIRST=1

# Одна PostgreSQL с CRM: не нужны TICKET_PG* — миграции GetBilet в той же БД
# GETBILET_USE_MAIN_DATABASE=1

# Каталог GET /api/bilet/events:
#   database — из getbilet_catalog_cache (локально/прод: обязателен POST .../sync-catalog, иначе пусто или демо на фронте)
#   database_fallback — сначала live GetBilet, при ошибке кэш (первый запрос всё ещё может быть очень долгим)
#   live — каждый раз обход Place→Stage→Repertoire (часто >60 с и 504 у Vite-прокси)
# Для разработки с Vite обычно нужен database + синхронизация каталога из админки GetBilet.
# GETBILET_CATALOG_SOURCE=database
#
# In-memory кэш ответа GET /api/bilet/events (секунды). 0 = выключено. Сбрасывается при POST .../sync-catalog.
# GETBILET_EVENTS_HTTP_CACHE_SEC=60

# Офферы GET /api/bilet/repertoire/:id/offers: кэш в PostgreSQL (миграция 075), фоновое обновление после SOFT_SEC
# GETBILET_OFFERS_CACHE=1
# GETBILET_OFFERS_CACHE_SOFT_SEC=45

# =============================================================================
# Оплата билетов — T-Bank (Tinkoff EACQ / Интернет-эквайринг)
# Личный кабинет: https://business.tbank.ru/oplata/main — TerminalKey и пароль
# Уведомления: URL в Init = {SITE_URL}/api/webhooks/tbank/eacq (тот же backend)
# =============================================================================
# TBANK_TERMINAL_KEY=
# TBANK_PASSWORD=
# Опционально: тестовый контур / другой хост API
# TBANK_EACQ_BASE_URL=https://securepay.tinkoff.ru/v2

