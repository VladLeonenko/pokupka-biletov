# Скопируй в backend/.env и подставь свои значения:
#   cp backend/.env.example backend/.env

# PostgreSQL — отдельная БД для проекта «Покупка Билетов»
PGUSER=pokupka_user
PGHOST=localhost
PGDATABASE=pokupka_biletov_dev
PGPASSWORD=changeme
PGPORT=5432

PORT=3000

# Локальная разработка: false = без проверки JWT на части роутов
AUTH_REQUIRED=false

JWT_SECRET=minimum-32-characters-secret-change-in-production

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-strong-password

CORS_ORIGIN=http://localhost:5173

# Прод: домен сайта (для ссылок в письмах и т.д.)
# SITE_URL=https://your-domain.ru

# Опционально
# OPENAI_API_KEY=
# OPENAI_PROXY_URL=
