# Production Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# Режим работы
NODE_ENV=production
PORT=3000

# Домен и CORS
SITE_URL=https://prime-coder.ru
CORS_ORIGIN=https://prime-coder.ru,https://www.prime-coder.ru

# База данных PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/primecoder_prod

# JWT секрет (используйте очень длинный случайный ключ)
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-characters

# OpenAI API (если используется)
OPENAI_API_KEY=sk-...

# Email настройки (если используется)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX=5

# SEO настройки
SEO_LOGO_URL=https://prime-coder.ru/legacy/img/logo.png

# Cold Lead Sales Pipeline (рассылки через UniSender)
# CRON_SECRET=secret-for-process-daily
# UNISENDER_API_KEY=ваш_ключ_api_unisender
# SENDER_EMAIL=sales@ваш-домен.ru
# SENDER_NAME=Команда PrimeCoder
# UNISENDER_CHANNEL_ID=398059676
# UNISENDER_LIST_ID=
# SALES_PIPELINE_BATCH_SIZE=20
# SALES_PIPELINE_MAX_EMAILS_PER_RUN=15
# Fallback на SMTP: EMAIL_HOST, EMAIL_USER, EMAIL_PASS
