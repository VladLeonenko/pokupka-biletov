# Копировать в .env.production для production build
# VITE_ префикс обязателен — Vite экспортирует только эти переменные на клиент

# Каноничный origin (meta og:url, JSON-LD, дублируется в scripts/fix-index-html.js)
VITE_SITE_URL=https://biletvsem.com

# Yandex.Metrika — ID счётчика (берётся из backend .env.prod: YANDEX_COUNTER_ID)
VITE_YANDEX_COUNTER_ID=106795462

# GetBilet — протокол и нужен ли cityId фронт берёт с GET /api/bilet/meta (бэкенд).
# BIL24: id города для GET_ACTIONS_V2
# VITE_GETBILET_CITY_ID=1
# Если задано и совпадает с бэкендом — лишний GET /api/bilet/meta перед афишей не выполняется (быстрее FCP).
# rest_v2 | rest | bil24_json | auto (пусто = как auto, один запрос /meta)
# VITE_GETBILET_PROTOCOL=rest_v2
